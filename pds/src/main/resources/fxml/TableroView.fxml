<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.effect.ColorAdjust?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="pds.gestiontareas.ui.TableroController"
           stylesheets="@../css/styles.css">

   <Region styleClass="fondo-imagen">
        <effect>
            <ColorAdjust saturation="-0.7" />
        </effect>
    </Region>
    
    <Region styleClass="filtro-gris" />
    <BorderPane>

        <top>
            <HBox spacing="15" styleClass="barra-superior">
                
                <Label text="Mi Tablero" styleClass="titulo"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="Bloquear Tablero" styleClass="btn-bloquear"/>
                
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" fitToHeight="false" styleClass="scroll">
                <content>
                    <HBox fx:id="contenedorListas" spacing="15" styleClass="contenedor-listas" alignment="TOP_LEFT">
                    </HBox>
                </content>
            </ScrollPane>
        </center>

    </BorderPane>
</StackPane>